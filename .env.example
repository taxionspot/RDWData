# App
NEXT_PUBLIC_PLATFORM_NAME=Kentekenrapport
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/plateintel
# Optional: direct Atlas URI without +srv (use this if SRV DNS fails in Node)
MONGODB_URI_DIRECT=
MONGODB_DB_NAME=plateintel
MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

# RDW Open Data
RDW_BASE_URL=https://opendata.rdw.nl/resource

# Analytics & consent (defaults are baked in; override only if the container changes)
NEXT_PUBLIC_GTM_ID=GTM-N4TS8CP9
NEXT_PUBLIC_COOKIEBOT_CBID=c95277a4-b000-4684-910e-1490969d79b1

# PayPal Checkout
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox default; set to https://api-m.paypal.com for live
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Admin Auth
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
# User auth
USER_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: Redis cache (Phase 2)
REDIS_URL=redis://localhost:6379

# IMAGIN vehicle images
NEXT_PUBLIC_IMAGIN_CUSTOMER_KEY=nl-kentekenrapport

# Anthropic Claude (server-side only)
ANTHROPIC_API_KEY=
# Example: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Debug logs for Anthropic SDK (dev only; ignored in production)
ANTHROPIC_DEBUG=false

# Email delivery via Resend (reports, thank-you and abandoned-checkout follow-up)
RESEND_API_KEY=
EMAIL_FROM=Anouk van Kentekenrapport <info@kentekenrapport.com>

# Abandoned checkout follow-up (cron, see vercel.json)
CRON_SECRET=replace-with-a-long-random-secret
# Minutes after last checkout activity before the follow-up email is sent
ABANDONED_CHECKOUT_DELAY_MINUTES=60

# Optional: show demo skip button even in production
NEXT_PUBLIC_ENABLE_DEMO_SKIP_PAYMENT=false
