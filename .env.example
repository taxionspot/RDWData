# App
NEXT_PUBLIC_PLATFORM_NAME=Kentekenrapport
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/plateintel
# Optional: direct Atlas URI without +srv (use this if SRV DNS fails in Node)
MONGODB_URI_DIRECT=
MONGODB_DB_NAME=plateintel
MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4

# RDW Open Data
RDW_BASE_URL=https://opendata.rdw.nl/resource

# PayPal Checkout
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox default; set to https://api-m.paypal.com for live
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Admin Auth
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
# User auth
USER_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: Redis cache (Phase 2)
REDIS_URL=redis://localhost:6379

# IMAGIN vehicle images.
# The default demo key returns WATERMARKED images. Removing the watermark
# requires a licensed imagin.studio customer key (paid plan) — set it here.
NEXT_PUBLIC_IMAGIN_CUSTOMER_KEY=nl-kentekenrapport

# Anthropic Claude (server-side only)
ANTHROPIC_API_KEY=
# Example: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Debug logs for Anthropic SDK (dev only; ignored in production)
ANTHROPIC_DEBUG=false

# Optional: email delivery for purchased reports (Resend)
RESEND_API_KEY=
REPORT_EMAIL_FROM=Kentekenrapport <noreply@kentekenrapport.nl>

# --- Demo / payment bypass ---
# SERVER-SIDE ENFORCEMENT (authoritative). When "true", report access is granted
# without a real payment and the /api/payments/access/[plate] demo-grant works.
# Never enable in production with real pricing. Default: disabled.
PAYMENT_DEMO_BYPASS=false
# UI ONLY: shows the "skip payment" button in the checkout modal. Has no effect
# on its own — the server still enforces PAYMENT_DEMO_BYPASS above.
NEXT_PUBLIC_ENABLE_DEMO_SKIP_PAYMENT=false
